---
import { ClientRouter } from "astro:transitions";
import "~/styles/global.css";
import SEO from "~/components/SEO.astro";
import PersonSchema from "~/components/PersonSchema.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  type?: "website" | "article" | "profile";
  image?: string;
  keywords?: string[];
  noindex?: boolean;
  includePersonSchema?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
}

const {
  title,
  description,
  path,
  type,
  image,
  keywords,
  noindex,
  includePersonSchema = false,
  publishedTime,
  modifiedTime,
  section,
} = Astro.props;

const normalizedPath = (path ?? Astro.url.pathname).replace(/\.html$/, "").replace(/\/$/, "") || "/";
const canonical = new URL(normalizedPath, "https://bominayoon.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,0..100;1,9..144,300..700,0..100&family=Instrument+Serif:ital@0;1&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..700,0..100;1,9..144,300..700,0..100&family=Instrument+Serif:ital@0;1&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <meta name="generator" content={Astro.generator} />
    <ClientRouter fallback="animate" />
    <SEO
      title={title}
      description={description}
      path={path}
      type={type}
      image={image}
      keywords={keywords}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      section={section}
    />
    {includePersonSchema && <PersonSchema />}
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-[color:var(--color-ink)] focus:text-[color:var(--color-paper)] focus:px-3 focus:py-2 focus:font-mono focus:text-xs focus:uppercase focus:tracking-wider">
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
