---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import Divider from "~/components/Divider.astro";
import VideoEmbed from "~/components/VideoEmbed.astro";
import { site } from "~/lib/site";

export async function getStaticPaths() {
  const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
  return projects.map((project, i) => ({
    params: { slug: project.id },
    props: {
      project,
      prev: projects[i - 1],
      next: projects[i + 1],
    },
  }));
}

const { project, prev, next } = Astro.props;
const { Content } = await render(project);
const { data } = project;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "@id": `${site.url}/projects/${project.id}#project`,
  name: data.title,
  alternativeHeadline: data.subtitle,
  description: data.summary,
  author: { "@type": "Person", name: site.name, url: site.url, "@id": `${site.url}#person` },
  creator: { "@type": "Person", name: site.name, url: site.url, "@id": `${site.url}#person` },
  temporalCoverage: data.period,
  keywords: data.tags.join(", "),
  url: `${site.url}/projects/${project.id}`,
  inLanguage: "en",
  about: data.tags.map((t) => ({ "@type": "Thing", name: t })),
};

const yearMatch = data.period.match(/\d{4}/);
const publishedTime = yearMatch ? `${yearMatch[0]}-01-01` : undefined;
---

<BaseLayout
  title={data.title}
  description={data.summary}
  path={`/projects/${project.id}`}
  type="article"
  keywords={data.tags}
  publishedTime={publishedTime}
  section="Projects"
  noindex={data.noindex}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <article class="mx-auto max-w-[1320px] px-6 md:px-10 pt-10 md:pt-14 pb-20" itemscope itemtype="https://schema.org/CreativeWork">
    <Breadcrumbs trail={[{ label: "Projects", href: "/projects" }, { label: data.title, href: `/projects/${project.id}` }]} />

    <header class="mt-10 md:mt-16 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-10">
      <div class="md:col-span-2 flex md:block items-center gap-4">
        <p class="eyebrow">№ {String(data.order).padStart(2, "0")}</p>
        <p class="eyebrow md:mt-1" itemprop="temporalCoverage">{data.period}</p>
        {data.status === "active" && <span class="chip md:mt-3 inline-block">Active</span>}
      </div>
      <div class="md:col-span-10 min-w-0">
        <h1 class="display-xl md:max-w-[22ch]" itemprop="name">
          <span class="underline-draw">{data.title}</span>
        </h1>
        {data.subtitle && (
          <p class="mt-4 md:mt-6 display-italic text-[1.1rem] md:text-[1.8rem] leading-[1.3] text-[color:var(--color-muted)] max-w-[60ch]" itemprop="alternativeHeadline">
            {data.subtitle}
          </p>
        )}
      </div>
    </header>

    <Divider variant="line" class="mt-12 md:mt-16" />

    <section class="mt-10 md:mt-12 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16" aria-labelledby="project-summary-heading">
      <aside class="md:col-span-4 min-w-0 space-y-6 md:space-y-8 md:sticky md:top-8 md:self-start" aria-label="Project metadata">
        <div>
          <p class="eyebrow mb-2">Role</p>
          <p class="text-[0.95rem] leading-[1.55]">{data.role}</p>
        </div>
        {data.partners.length > 0 && (
          <div>
            <p class="eyebrow mb-2">Partners</p>
            <ul class="space-y-1.5 text-[0.92rem] leading-[1.5]">
              {data.partners.map((partner) => <li>· {partner}</li>)}
            </ul>
          </div>
        )}
        {data.tags.length > 0 && (
          <div>
            <p class="eyebrow mb-2">Domains</p>
            <ul class="flex flex-wrap gap-1.5">
              {data.tags.map((t) => <li class="chip" itemprop="keywords">{t}</li>)}
            </ul>
          </div>
        )}
      </aside>

      <div class="md:col-span-8 min-w-0">
        <p class="eyebrow mb-4" id="project-summary-heading">Summary</p>
        <p class="font-serif text-[1.1rem] md:text-[1.35rem] leading-[1.5] text-[color:var(--color-ink)] max-w-[60ch]" itemprop="description">
          {data.summary}
        </p>

        {data.outcomes.length > 0 && (
          <div class="mt-10 md:mt-12">
            <p class="eyebrow mb-4">Outcomes</p>
            <ol class="space-y-3 max-w-[62ch]">
              {data.outcomes.map((o, i) => (
                <li class="grid grid-cols-[1.75rem_1fr] gap-2 md:gap-3 text-[0.9rem] md:text-[0.95rem] leading-[1.55]">
                  <span class="font-mono text-[0.68rem] md:text-[0.72rem] tracking-wider text-[color:var(--color-muted)] pt-1">{String(i + 1).padStart(2, "0")}</span>
                  <span>{o}</span>
                </li>
              ))}
            </ol>
          </div>
        )}
      </div>
    </section>

    {data.videos.length > 0 && (
      <>
        <Divider variant="asterism" class="mt-16 md:mt-20 mb-10 md:mb-14" />
        <section class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-16" aria-labelledby="project-videos-heading">
          <div class="md:col-span-2">
            <p class="eyebrow" id="project-videos-heading">Videos</p>
          </div>
          <div class="md:col-span-10 min-w-0">
            {data.videos.map((v) => (
              <VideoEmbed url={v.url} title={v.title} caption={v.caption} />
            ))}
          </div>
        </section>
      </>
    )}

    <Divider variant="asterism" class="mt-16 md:mt-20 mb-10 md:mb-14" />

    <section class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-16" aria-label="Project narrative">
      <div class="md:col-span-2 hidden md:block">
        <p class="eyebrow">Narrative</p>
      </div>
      <div class="md:col-span-10 min-w-0">
        <div class="prose" itemprop="articleBody">
          <Content />
        </div>
      </div>
    </section>

    <Divider variant="line" class="mt-24" />

    <nav class="mt-10 grid grid-cols-2 gap-6" aria-label="Project navigation">
      {prev ? (
        <a href={`/projects/${prev.id}`} class="group block">
          <p class="eyebrow mb-2">← Previous</p>
          <p class="font-serif text-[1.1rem] md:text-[1.3rem] leading-[1.2] max-w-[34ch] group-hover:opacity-70 transition">
            <span class="underline-draw">{prev.data.title}</span>
          </p>
        </a>
      ) : <span />}
      {next ? (
        <a href={`/projects/${next.id}`} class="group block text-right">
          <p class="eyebrow mb-2">Next →</p>
          <p class="font-serif text-[1.1rem] md:text-[1.3rem] leading-[1.2] max-w-[34ch] ml-auto group-hover:opacity-70 transition">
            <span class="underline-draw">{next.data.title}</span>
          </p>
        </a>
      ) : <span />}
    </nav>
  </article>
</BaseLayout>
