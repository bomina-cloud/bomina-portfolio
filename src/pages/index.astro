---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import RevealOnScroll from "~/components/RevealOnScroll.astro";
import Divider from "~/components/Divider.astro";
import { site } from "~/lib/site";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((p) => p.data.featured);
const lead = featured[0];
const featuredRest = featured.slice(1);
const publications = (await getCollection("publications")).sort((a, b) => a.data.order - b.data.order);

const years = {
  start: Math.min(...projects.map((p) => parseInt(p.data.period.match(/\d{4}/)?.[0] ?? "2004"))),
  end: new Date().getFullYear(),
};
---

<BaseLayout
  description={site.tagline}
  path="/"
  type="profile"
  includePersonSchema={true}
  keywords={["portfolio", "research archive", "future city", "advanced materials", "curriculum vitae"]}
>
  <section class="mx-auto max-w-[1320px] px-6 md:px-10 pt-10 md:pt-16 pb-14 md:pb-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-10">
      <div class="md:col-span-2 order-2 md:order-1 flex md:flex-col items-center md:items-start justify-between md:pt-3 gap-4">
        <p class="eyebrow leading-relaxed md:max-w-[12ch]">{years.start}<br class="hidden md:block" />— {years.end}</p>
        <p class="eyebrow leading-relaxed text-right md:text-left">Ph.D.<br class="hidden md:block" />Industrial<br class="hidden md:block" />Design</p>
      </div>

      <div class="md:col-span-10 order-1 md:order-2 min-w-0">
        <p class="eyebrow mb-6 md:mb-8">Future Mobility Strategist · Senior Manager, Hyundai Motor Group</p>
        <h1 class="display-xl md:max-w-[18ch]">
          Designing how <span class="display-italic">future mobility</span> gets decided —
          <span class="opacity-60">across scenarios, architectures, and organizations.</span>
        </h1>

        <div class="mt-14 md:mt-20 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-14 items-start">
          <div class="md:col-span-7">
            <p class="max-w-[62ch] text-[1.05rem] leading-[1.65] text-[color:var(--color-ink-soft)]">
              I'm <strong>Bomina Yoon</strong> <span class="text-[color:var(--color-muted)]">(윤보미나)</span> — a future mobility strategist and industrial designer with <strong>21 years at Hyundai Motor Group</strong>. I build corporate-scale programs that turn foresight into shipped systems — <em>AI strategy roadmaps, autonomous logistics infrastructure, Software-Defined Vehicle transformation,</em> and <em>biomimicry-driven R&amp;D</em>. My work has guided CEO-level decisions, informed CES flagships, and shaped group-wide 10–15 year strategic directions.
            </p>
            <div class="mt-10 flex flex-wrap gap-2.5">
              <a href="/projects" class="pill">Selected Projects →</a>
              <a href="/publications" class="pill ghost">Publications</a>
              <a href={`mailto:${site.email}`} class="pill ghost">Get in touch</a>
            </div>
          </div>
          <aside class="md:col-span-5 md:pl-10 md:border-l border-[color:var(--color-line)] space-y-6">
            <div>
              <p class="eyebrow mb-2">Currently</p>
              <p class="text-[0.95rem] leading-[1.55]">
                Leading the corporate-wide biomimicry R&amp;D framework and Hyundai–Toray advanced materials
                strategy. Building toward <strong>CES 2027</strong>.
              </p>
            </div>
            <div class="rule-soft"></div>
            <div>
              <p class="eyebrow mb-2">Past signals</p>
              <ul class="text-[0.92rem] leading-[1.55] space-y-1.5 text-[color:var(--color-ink-soft)]">
                <li>· CES 2024 DICE — experience lead &amp; chief architect</li>
                <li>· NEOM Hub-less Mega Port — validated by NEOM CEO, 2022</li>
                <li>· 2050 Future City — Hub Solution at CES 2020</li>
                <li>· Hyundai–Kia M-30 Pre-Concept process — officially adopted</li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <Divider variant="asterism" class="mx-auto max-w-[1320px] px-6 md:px-10" />

  <section class="mx-auto max-w-[1320px] px-6 md:px-10 py-20 md:py-28" aria-labelledby="featured-heading">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-10 mb-10 md:mb-14">
      <div class="md:col-span-3">
        <p class="eyebrow">§ 01 — Selected Projects</p>
      </div>
      <div class="md:col-span-9 min-w-0 flex flex-col md:flex-row md:items-end md:justify-between gap-4 md:gap-6">
        <h2 id="featured-heading" class="display-lg md:max-w-[18ch]">
          Programs that <span class="display-italic">outlive</span> the concepts they seed.
        </h2>
        <a href="/projects" class="pill ghost whitespace-nowrap hidden md:inline-flex">View all ({projects.length})</a>
      </div>
    </div>

    {lead && (
      <RevealOnScroll as="article" class="mb-14 md:mb-28">
        <a href={`/projects/${lead.id}`} class="group block grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-10">
          <div class="md:col-span-2 flex md:flex-col md:justify-between md:pt-2 items-center md:items-start gap-4">
            <span class="font-mono text-[0.72rem] tracking-[0.18em] text-[color:var(--color-muted)]">{String(lead.data.order).padStart(2, "0")}</span>
            <span class="font-mono text-[0.72rem] tracking-[0.18em] text-[color:var(--color-muted)]">{lead.data.period}</span>
          </div>
          <div class="md:col-span-10 min-w-0">
            <h3 class="display-lg md:max-w-[22ch] group-hover:opacity-80 transition">
              <span class="underline-draw">{lead.data.title}</span>
            </h3>
            {lead.data.subtitle && (
              <p class="mt-4 md:mt-5 display-italic text-[1.1rem] md:text-[1.7rem] leading-[1.3] text-[color:var(--color-muted)] max-w-[54ch]">
                {lead.data.subtitle}
              </p>
            )}
            <p class="mt-6 md:mt-8 max-w-[72ch] text-[0.95rem] md:text-[1rem] leading-[1.65] text-[color:var(--color-ink-soft)]">
              {lead.data.summary}
            </p>
            <div class="mt-5 md:mt-6 flex flex-wrap gap-1.5 md:gap-2">
              {lead.data.tags.slice(0, 5).map((t) => <span class="chip">{t}</span>)}
            </div>
          </div>
        </a>
      </RevealOnScroll>
    )}

    <ol class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16 md:gap-y-20">
      {featuredRest.map((p, i) => (
        <RevealOnScroll as="li" delay={i * 80}>
          <a href={`/projects/${p.id}`} class="group block">
            <div class="flex items-baseline justify-between mb-4">
              <span class="font-mono text-[0.72rem] tracking-[0.18em] text-[color:var(--color-muted)]">{String(p.data.order).padStart(2, "0")} · {p.data.period}</span>
              {p.data.status === "active" && <span class="chip">Active</span>}
            </div>
            <h3 class="display-md md:max-w-[24ch] group-hover:opacity-80 transition">
              <span class="underline-draw">{p.data.title}</span>
            </h3>
            {p.data.subtitle && (
              <p class="mt-3 display-italic text-[0.95rem] md:text-[1.05rem] leading-[1.3] text-[color:var(--color-muted)] max-w-[46ch]">{p.data.subtitle}</p>
            )}
            <p class="mt-4 md:mt-5 text-[0.9rem] md:text-[0.95rem] leading-[1.6] text-[color:var(--color-ink-soft)] max-w-[54ch]">
              {p.data.summary}
            </p>
            <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1 text-[0.65rem] font-mono uppercase tracking-[0.18em] text-[color:var(--color-muted)]">
              {p.data.tags.slice(0, 4).map((t) => <span>· {t}</span>)}
            </div>
          </a>
        </RevealOnScroll>
      ))}
    </ol>

    <div class="mt-20 flex justify-center md:hidden">
      <a href="/projects" class="pill ghost">View all {projects.length} projects →</a>
    </div>
  </section>

  <Divider variant="asterism" class="mx-auto max-w-[1320px] px-6 md:px-10" />

  <section class="mx-auto max-w-[1320px] px-6 md:px-10 py-20 md:py-28" aria-labelledby="publications-heading">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-10 mb-10 md:mb-12">
      <div class="md:col-span-3">
        <p class="eyebrow">§ 02 — Research</p>
      </div>
      <div class="md:col-span-9 min-w-0 flex flex-col md:flex-row md:items-end md:justify-between gap-4 md:gap-6">
        <h2 id="publications-heading" class="display-lg md:max-w-[20ch]">
          Peer-reviewed work on <span class="display-italic">pre-concept</span> design and co-design innovation.
        </h2>
        <a href="/publications" class="pill ghost whitespace-nowrap hidden md:inline-flex">All {publications.length}</a>
      </div>
    </div>

    <ol class="divide-y divide-[color:var(--color-line)]">
      {publications.slice(0, 4).map((p) => (
        <li class="grid grid-cols-[3rem_1fr] md:grid-cols-12 gap-3 md:gap-10 py-6 md:py-7">
          <span class="md:col-span-1 font-mono text-[0.72rem] md:text-[0.78rem] tracking-wider text-[color:var(--color-muted)] md:pt-1">{p.data.year}</span>
          <div class="md:col-span-11 min-w-0">
            <h3 class="font-serif italic text-[1.05rem] md:text-[1.35rem] leading-[1.3] text-[color:var(--color-ink)]">{p.data.title}</h3>
            <p class="mt-2 text-[0.8rem] md:text-[0.85rem] text-[color:var(--color-muted)]">
              {p.data.authors.join(", ")} · {p.data.venue}{p.data.volume ? `, ${p.data.volume}` : ""}{p.data.pages ? `, ${p.data.pages}` : ""}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <Divider variant="asterism" class="mx-auto max-w-[1320px] px-6 md:px-10" />

  <section class="mx-auto max-w-[1320px] px-6 md:px-10 py-24 md:py-32" aria-label="Contact summary">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 md:items-end">
      <div class="md:col-span-8 min-w-0">
        <p class="eyebrow mb-5 md:mb-6">§ 03 — Contact</p>
        <h2 class="display-xl md:max-w-[14ch]">
          Let's talk about <span class="display-italic">where mobility goes next</span>.
        </h2>
        <a href={`mailto:${site.email}`} class="inline-block mt-8 md:mt-10 font-display text-[1.4rem] md:text-[2.4rem] leading-none tracking-tight underline-draw break-all">{site.email}</a>
      </div>
      <div class="md:col-span-4 min-w-0">
        <div class="rule-soft mb-6"></div>
        <p class="eyebrow mb-3">Based in</p>
        <p class="font-serif italic text-[1.05rem] md:text-[1.1rem]">{site.location}</p>
        <p class="eyebrow mt-6 mb-3">Open to</p>
        <ul class="text-[0.92rem] leading-[1.55] text-[color:var(--color-ink-soft)] space-y-1">
          <li>· Advisory &amp; board roles</li>
          <li>· Long-horizon strategy collaborations</li>
          <li>· Keynote &amp; workshop facilitation</li>
          <li>· Academic &amp; industry partnerships</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
