---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import RevealOnScroll from "~/components/RevealOnScroll.astro";
import Divider from "~/components/Divider.astro";
import { site } from "~/lib/site";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${site.url}/projects#collection`,
  name: "Projects — Bomina Yoon",
  description:
    "Selected programs by Bomina Yoon spanning autonomous logistics, immersive mobility media, future-city foresight, AI strategy, biomimicry R&D, advanced materials, and SDV transformation.",
  url: `${site.url}/projects`,
  about: {
    "@type": "Person",
    name: site.name,
    url: site.url,
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: projects.length,
    itemListElement: projects.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${site.url}/projects/${p.id}`,
      name: p.data.title,
    })),
  },
};

const tagCounts = new Map<string, number>();
projects.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)));
const topTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([t]) => t);
---

<BaseLayout
  title="Projects"
  description="Selected programs by Bomina Yoon — autonomous logistics (NEOM), immersive mobility media (CES 2024 DICE), 2050 future-city foresight, AI strategy, biomimicry-driven R&D, advanced materials (Toray), and SDV transformation."
  path="/projects"
  keywords={["projects", "case studies", "portfolio", "research programs"]}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <section class="mx-auto max-w-[1320px] px-6 md:px-10 pt-10 md:pt-16 pb-10">
    <Breadcrumbs trail={[{ label: "Projects", href: "/projects" }]} />
    <div class="mt-8 md:mt-10 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-10">
      <div class="md:col-span-2 flex md:block items-center gap-4">
        <p class="eyebrow">{projects.length} Programs</p>
        <p class="eyebrow md:mt-1">2004 – Present</p>
      </div>
      <div class="md:col-span-10 min-w-0">
        <h1 class="display-xl md:max-w-[18ch]">
          Selected programs across <span class="display-italic">foresight, architecture,</span> and execution.
        </h1>
        <div class="mt-6 md:mt-8 flex flex-wrap gap-1.5 md:gap-2 md:max-w-[70ch]">
          {topTags.map((t) => <span class="chip">{t}</span>)}
        </div>
      </div>
    </div>
  </section>

  <Divider variant="asterism" class="mx-auto max-w-[1320px] px-6 md:px-10 mt-6" />

  <section class="mx-auto max-w-[1320px] px-6 md:px-10 py-6 md:py-10">
    <ol class="divide-y divide-[color:var(--color-line)]">
      {projects.map((p, i) => (
        <RevealOnScroll as="li" delay={Math.min(i * 40, 320)}>
          <a href={`/projects/${p.id}`} class="group block py-8 md:py-14 grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-10 items-start">
            <span class="md:col-span-1 font-mono text-[0.72rem] md:text-[0.78rem] tracking-[0.18em] text-[color:var(--color-muted)] md:pt-3">{String(p.data.order).padStart(2, "0")}</span>
            <div class="md:col-span-7 min-w-0">
              <p class="eyebrow mb-3">{p.data.period}{p.data.status === "active" ? " · Active" : ""}</p>
              <h2 class="display-md md:max-w-[28ch] group-hover:opacity-80 transition">
                <span class="underline-draw">{p.data.title}</span>
              </h2>
              {p.data.subtitle && (
                <p class="mt-3 display-italic text-[0.95rem] md:text-[1.15rem] leading-[1.3] text-[color:var(--color-muted)] max-w-[56ch]">{p.data.subtitle}</p>
              )}
              <p class="mt-4 md:mt-5 max-w-[64ch] text-[0.9rem] md:text-[0.95rem] leading-[1.6] text-[color:var(--color-ink-soft)]">{p.data.summary}</p>
            </div>
            <div class="md:col-span-4 md:pt-12 flex flex-wrap gap-1.5">
              {p.data.tags.map((t) => <span class="chip">{t}</span>)}
            </div>
          </a>
        </RevealOnScroll>
      ))}
    </ol>
  </section>
</BaseLayout>
